{
  "manifest_version": 3,
  "name": "FlowTrace QA",
  "version": "1.0.0",
  "description": "Record UI actions and correlate with API calls for test automation",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "devtools_page": "devtools.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["utils/*.js", "inpage-interceptor.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "incognito": "split"
}
